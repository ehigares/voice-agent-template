# ============================================================
# Voice Agent Template — Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# Layer 1 — Telephony (Telnyx)
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=           # Your purchased Telnyx phone number (+1XXXXXXXXXX)

# Layer 2 — Orchestration (Vapi)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=           # REQUIRED — secret for HMAC-SHA256 webhook verification

# Layer 3 — Speech
DEEPGRAM_API_KEY=              # STT: Deepgram Nova-3
CARTESIA_API_KEY=              # TTS: Cartesia Sonic (default)
ELEVENLABS_API_KEY=            # TTS: ElevenLabs (optional, premium swap)

# Layer 4 — LLM
ANTHROPIC_API_KEY=             # Claude Haiku/Sonnet via Vapi

# Layer 5 — Automation
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=                   # n8n API key for workflow deployment

# Layer 6 — Memory
SUPABASE_URL=                  # Your Supabase project URL
SUPABASE_SERVICE_KEY=          # Supabase service role key (not anon key)

# Feature flags — set to false to disable per-client
ENABLE_PINECONE=true           # Set false to disable knowledge base search
ENABLE_MEM0=true               # Set false to disable persistent caller memory

PINECONE_API_KEY=
PINECONE_INDEX=voice-agent     # Pinecone index name (1536 dims, cosine)
MEM0_API_KEY=                  # Mem0 persistent caller memory

# Embeddings — REQUIRED for knowledge base and training pipeline
OPENAI_API_KEY=                # REQUIRED — used for generating embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536      # Must match EMBEDDING_MODEL output dimensions

# Layer 7 — Training
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=voice-agent-recordings
STORAGE_ENDPOINT=              # Leave blank for AWS S3.
                               # Set to http://localhost:9000 for local MinIO.
ASSEMBLYAI_API_KEY=            # Transcription + speaker diarization

# Server
WEBHOOK_PORT=3000
MAX_CONCURRENT_CALLS=20        # Tune per Railway instance size
NODE_ENV=development
