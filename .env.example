# ============================================================
# Voice Agent Template — Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# Layer 1 — Telephony (Telnyx)
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=           # Your purchased Telnyx phone number (+1XXXXXXXXXX)

# Layer 2 — Orchestration (Vapi)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=           # Secret for verifying Vapi webhook signatures

# Layer 3 — Speech
DEEPGRAM_API_KEY=              # STT: Deepgram Nova-3
CARTESIA_API_KEY=              # TTS: Cartesia Sonic (default)
ELEVENLABS_API_KEY=            # TTS: ElevenLabs (optional, premium swap)

# Layer 4 — LLM
ANTHROPIC_API_KEY=             # Claude Haiku/Sonnet via Vapi

# Layer 5 — Automation
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=                   # n8n API key for workflow deployment

# Layer 6 — Memory
SUPABASE_URL=                  # Your Supabase project URL
SUPABASE_SERVICE_KEY=          # Supabase service role key (not anon key)
PINECONE_API_KEY=
PINECONE_INDEX=voice-agent     # Pinecone index name (1536 dims, cosine)
OPENAI_API_KEY=                # Used for generating embeddings only
MEM0_API_KEY=                  # Mem0 persistent caller memory

# Layer 7 — Training
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=voice-agent-recordings
ASSEMBLYAI_API_KEY=            # Transcription + speaker diarization

# Server
WEBHOOK_PORT=3000
NODE_ENV=development
